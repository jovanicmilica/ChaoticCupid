<?xml version="1.0" encoding="utf-8" ?>
<configuration>
	<system.serviceModel>
		<services>
			<service name="ChaoticCupid.Service.CupidService">
				<endpoint address=""
						  binding="netTcpBinding"
						  contract="ChaoticCupid.Service.Contracts.IPersonService"/>
				<endpoint address="mex"
						  binding="mexTcpBinding"
						  contract="IMetadataExchange"/>
				<host>
					<baseAddresses>
						<add baseAddress="net.tcp://localhost:8080/CupidService"/>
					</baseAddresses>
				</host>
			</service>
		</services>
		<behaviors>
			<serviceBehaviors>
				<behavior>
					<serviceMetadata/>
					<serviceDebug includeExceptionDetailInFaults="true"/>
				</behavior>
			</serviceBehaviors>
		</behaviors>
	</system.serviceModel>
</configuration>